# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email (forms) - Resend or SMTP. Phase 7.
RESEND_API_KEY=
CONTACT_TO_EMAIL=enquiry@dnhhapur.com

# Payload CMS — phase 5.
# Local Docker compose ships a Postgres on localhost:5432 with these creds.
DATABASE_URI=postgresql://dnh:dnh@db:5432/dnh
# Generate with `openssl rand -base64 32` before deploying.
PAYLOAD_SECRET=dev-secret-change-me

# Optional analytics — phase 9.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
